<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.CustomerDetailPage"
             Title="Customer Detail">

       <Grid>

              <!-- Content — hidden while loading -->
              <ScrollView x:Name="ContentArea"
                            IsVisible="False">
                     <VerticalStackLayout Padding="24"
                                   Spacing="20">

                            <!-- Avatar + name + status header -->
                            <VerticalStackLayout HorizontalOptions="Center"
                                          Spacing="10">

                                   <Border x:Name="AvatarCircle"
                                           BackgroundColor="#512BD4"
                                           StrokeShape="Ellipse"
                                           StrokeThickness="0"
                                           HeightRequest="80"
                                           WidthRequest="80"
                                           HorizontalOptions="Center">
                                          <Label x:Name="InitialsLabel"
                                                 TextColor="White"
                                                 FontSize="28"
                                                 FontAttributes="Bold"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center"/>
                                   </Border>

                                   <Label x:Name="NameLabel"
                                          FontSize="22"
                                          FontAttributes="Bold"
                                          HorizontalOptions="Center"
                                          TextColor="#1A1A1A"/>

                                   <!-- Status pill -->
                                   <Border x:Name="StatusBadge"
                                           StrokeThickness="0"
                                           StrokeShape="RoundRectangle 10"
                                           Padding="14,5"
                                           HorizontalOptions="Center">
                                          <Label x:Name="StatusLabel"
                                                 FontSize="12"
                                                 FontAttributes="Bold"
                                                 TextColor="White"/>
                                   </Border>

                            </VerticalStackLayout>

                            <!-- Contact information card -->
                            <Border Stroke="#E8E8E8"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Padding="20"
                                    BackgroundColor="White">
                                   <VerticalStackLayout Spacing="16">

                                          <Label Text="CONTACT INFORMATION"
                                                 FontSize="11"
                                                 FontAttributes="Bold"
                                                 TextColor="Gray"
                                                 CharacterSpacing="1"/>

                                          <Grid ColumnDefinitions="90,*"
                                                RowDefinitions="Auto,Auto"
                                                ColumnSpacing="12"
                                                RowSpacing="14">

                                                 <Label Grid.Row="0"
                                                               Grid.Column="0"
                                                        Text="Email"
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        TextColor="#444"
                                                        VerticalOptions="Center"/>
                                                 <Label x:Name="EmailLabel"
                                                        Grid.Row="0"
                                                               Grid.Column="1"
                                                        FontSize="14"
                                                        TextColor="#222"
                                                        LineBreakMode="TailTruncation"
                                                        VerticalOptions="Center"/>

                                                 <Label Grid.Row="1"
                                                               Grid.Column="0"
                                                        Text="Phone"
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        TextColor="#444"
                                                        VerticalOptions="Center"/>
                                                 <Label x:Name="PhoneLabel"
                                                        Grid.Row="1"
                                                               Grid.Column="1"
                                                        FontSize="14"
                                                        TextColor="#222"
                                                        VerticalOptions="Center"/>

                                          </Grid>
                                   </VerticalStackLayout>
                            </Border>

                            <!-- Account information card -->
                            <Border Stroke="#E8E8E8"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Padding="20"
                                    BackgroundColor="White">
                                   <VerticalStackLayout Spacing="16">

                                          <Label Text="ACCOUNT INFORMATION"
                                                 FontSize="11"
                                                 FontAttributes="Bold"
                                                 TextColor="Gray"
                                                 CharacterSpacing="1"/>

                                          <Grid ColumnDefinitions="90,*"
                                                ColumnSpacing="12">
                                                 <Label Grid.Column="0"
                                                        Text="Created"
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        TextColor="#444"
                                                        VerticalOptions="Center"/>
                                                 <Label x:Name="CreatedAtLabel"
                                                        Grid.Column="1"
                                                        FontSize="14"
                                                        TextColor="#222"
                                                        VerticalOptions="Center"/>
                                          </Grid>

                                   </VerticalStackLayout>
                            </Border>

                     </VerticalStackLayout>
              </ScrollView>

              <!-- Loading spinner — shown while fetching, sits on top -->
              <ActivityIndicator x:Name="LoadingIndicator"
                                 IsRunning="True"
                                 IsVisible="True"
                                 Color="#512BD4"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"/>

       </Grid>

</ContentPage>
