@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize] 

@using Application.DTO
@using Application.Services.Tickets
@inject ITicketService TicketService

@using Web.Components.Shared

<PageTitle>Home</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Welcome to CRM Demo</MudText>
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <StatsCard Title="Total Tickets" Value="@totalTickets.ToString()" Subtitle="All tickets" ValueColor="Color.Primary" Icon="Icons.Material.Filled.Assignment" TrendText="23%"/>
        </MudItem>
        @foreach (var statusCount in ticketStatusCounts)
        {
            <MudItem xs="12" sm="6" md="4">
                <StatsCard Title="@statusCount.Status.ToString()" Value="@statusCount.Count.ToString()" Subtitle="Tickets with this status" ValueColor="Color.Primary" Icon="Icons.Material.Filled.Assignment" />
            </MudItem>
        }
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" sm="6" md="6">
            @if(Series.Count > 0){
                <MudChart 
                    ChartType="ChartType.Pie" 
                    ChartSeries="@Series" 
                    XAxisLabels="@Labels" 
                    ChartOptions="@Options"
                    Width="300px" Height="300px" />
            }
        </MudItem>
        <MudItem xs="12" sm="6" md="6">
            @if(Series.Count > 0){
                <MudChart 
                    ChartType="ChartType.StackedBar" 
                    ChartSeries="@Series" 
                    XAxisLabels="@Labels" 
                    ChartOptions="@Options"
                    Width="300px" Height="300px" />
            }
        </MudItem>
        <MudItem xs="12" sm="6" md="6">
            @if(Series.Count > 0){
                <MudChart 
                    ChartType="ChartType.Line" 
                    ChartSeries="@Series" 
                    XAxisLabels="@Labels" 
                    ChartOptions="@Options"
                    Width="500px" Height="500px" />
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<StatusCountDTO> ticketStatusCounts = new List<StatusCountDTO>();
    private int totalTickets => ticketStatusCounts.Sum(t => t.Count);
    private List<ChartSeries> Series = new();
    private string[] Labels = Array.Empty<string>();

    private ChartOptions Options = new ChartOptions
    {
        YAxisLines = true,
        XAxisLines = false
    };
    protected override void OnInitialized()
    {
        LoadTicketStatusCounts();
    }
    private void LoadTicketStatusCounts()
    {
        ticketStatusCounts = TicketService.GetTicketCountsByStatus();

        // Prepare data for the chart
        Series = new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Tickets",
                Data = ticketStatusCounts.Select(t => (double)t.Count).ToArray()
            }
        };
        Labels = ticketStatusCounts.Select(t => t.Status.ToString()).ToArray();
    }
}
