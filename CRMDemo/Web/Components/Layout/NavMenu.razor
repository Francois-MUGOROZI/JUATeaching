<MudStack Spacing="2" Class="nav-root">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="nav-brand">
        <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Filled">CRM</MudAvatar>
        <MudStack Spacing="0" Class="ml-3">
            <MudText Typo="Typo.subtitle1" Class="nav-brand-title">CRM Demo</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Operations</MudText>
        </MudStack>
    </MudStack>

    <MudDivider />

    <MudNavMenu Dense="true" Class="nav-menu" Color="Color.Primary">
        <MudNavLink Href="/" 
                    Match="NavLinkMatch.All" 
                    Icon="@Icons.Material.Filled.Dashboard"
                    Class="nav-link">
            Dashboard
        </MudNavLink>
    </MudNavMenu>

    <MudNavMenu Dense="true" Class="nav-menu" Color="Color.Primary">
        <MudNavLink Href="/customers" 
                    Match="NavLinkMatch.All" 
                    Icon="@Icons.Material.Filled.People"
                    Class="nav-link">
            Customers
        </MudNavLink>
        
        <MudNavLink Href="/tickets" 
                    Match="NavLinkMatch.All" 
                    Icon="@Icons.Material.Filled.SupportAgent"
                    Class="nav-link">
            Tickets
        </MudNavLink>
        
        <MudNavLink Href="/campaigns" 
                    Match="NavLinkMatch.All" 
                    Icon="@Icons.Material.Filled.Campaign"
                    Class="nav-link">
            Campaigns
        </MudNavLink>
        
        <AuthorizeView Roles="Admin">
            <MudNavLink Href="/users" 
                        Match="NavLinkMatch.All" 
                        Icon="@Icons.Material.Filled.Person"
                        Class="nav-link">
                Users
            </MudNavLink>
        </AuthorizeView>
    </MudNavMenu>
</MudStack>
