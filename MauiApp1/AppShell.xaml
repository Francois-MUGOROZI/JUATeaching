<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp1"
    xmlns:pages="clr-namespace:MauiApp1.Pages"
    Title="MauiApp1"
    BackgroundColor="#512BD4"
    ForegroundColor="White"
    TitleColor="White"
    UnselectedColor="#C0A8F0">
    <!--
        Styling set on the Shell element applies to every page automatically.
        No need to repeat it on individual pages.

        BackgroundColor  → bar background
        ForegroundColor  → icons, back arrow
        TitleColor       → page title text
        UnselectedColor  → unselected tab icons/labels
    -->

    <!-- Global app bar: brand logo on the left, current page title in centre, avatar on the right -->
    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto"
              Padding="4,0"
              VerticalOptions="Center">

            <!-- Brand: logo icon only -->
            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle 6"
                    StrokeThickness="0"
                    BackgroundColor="Transparent"
                    Padding="2"
                    VerticalOptions="Center">
                <Image Source="dotnet_bot.png"
                       HeightRequest="28"
                       WidthRequest="28"
                       Aspect="AspectFit"/>
            </Border>

            <!-- Current page title (updates on navigation) -->
            <Label Grid.Column="1"
                   Text="{Binding CurrentTitle}"
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <!-- User avatar action button -->
            <Border Grid.Column="2"
                    x:Name="AvatarBorder"
                    StrokeShape="Ellipse"
                    Stroke="White"
                    StrokeThickness="1.5"
                    HeightRequest="36"
                    WidthRequest="36"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                </Border.GestureRecognizers>
                <Image Source="dotnet_bot.png"
                       Aspect="AspectFill"
                       HeightRequest="36"
                       WidthRequest="36"/>
            </Border>

        </Grid>
    </Shell.TitleView>

    <TabBar>

        <Tab Title="Home"
             Icon="home.png">
            <ShellContent
                Route="home"
                ContentTemplate="{DataTemplate local:MainPage}"/>
        </Tab>

        <Tab Title="Customers"
             Icon="customers.png">
            <ShellContent
                Route="customers"
                ContentTemplate="{DataTemplate pages:CustomersPage}"/>
        </Tab>

        <Tab Title="Tickets"
             Icon="tickets.png">
            <ShellContent
                Route="tickets"
                ContentTemplate="{DataTemplate pages:TicketsPage}"/>
        </Tab>

        <Tab Title="Users"
             Icon="customers.png">
            <ShellContent
                Route="users"
                ContentTemplate="{DataTemplate pages:UsersPage}"/>
        </Tab>

    </TabBar>

</Shell>
